{
  "compilerOptions": {
    "target": "ES6",
    "lib": ["ES6", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "outDir": ".",
    "rootDir": "src",
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "types": ["svelte", "obsidian"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}